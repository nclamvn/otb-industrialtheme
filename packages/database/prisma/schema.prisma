// ============================================
// PRODUCT MEDIA SYSTEM - PHASE 3
// ============================================

enum MediaType {
  HERO // 1200×1600 - Primary product image
  CARD // 600×800 - Product cards
  THUMBNAIL // 400×400 - Quick thumbnails
  MINI // 64×64 - Grid/table icons
  ZOOM // Up to 4000px - Detail view
  SWATCH // Color swatch
  LIFESTYLE // Marketing/lifestyle shots
  FLAT_LAY // Flat lay shots
  DETAIL // Detail close-ups
  VIDEO_THUMB // Video thumbnail
}

enum MediaStatus {
  UPLOADING // File being uploaded
  PROCESSING // Generating variants
  READY // All variants ready
  FAILED // Processing failed
  ARCHIVED // Soft deleted
}

enum MediaSource {
  UPLOAD // Manual upload
  SUPPLIER // From supplier/brand
  AI_GENERATED // AI generated placeholder
  EXTERNAL // External URL
}

model ProductMedia {
  id String @id @default(cuid())

  // SKU Reference
  skuItemId String?
  skuItem   SKUItem? @relation("SKUItemMedia", fields: [skuItemId], references: [id], onDelete: Cascade)

  // Alternative references for flexibility
  styleCode String? // Style-level media (shared across colors)
  colorCode String? // Color-level media

  // Media Identification
  type      MediaType   @default(HERO)
  status    MediaStatus @default(UPLOADING)
  source    MediaSource @default(UPLOAD)
  sortOrder Int         @default(0)
  isPrimary Boolean     @default(false)

  // Original File Info
  originalUrl      String
  originalFilename String
  originalMimeType String
  originalSize     Int // bytes
  originalWidth    Int?
  originalHeight   Int?

  // Processed Variants (stored as JSON for flexibility)
  variants Json? // { hero: url, card: url, thumb: url, mini: url, zoom: url }

  // Individual variant URLs (for quick access)
  heroUrl  String? // 1200×1600
  cardUrl  String? // 600×800
  thumbUrl String? // 400×400
  miniUrl  String? // 64×64
  zoomUrl  String? // Up to 4000px

  // Image Analysis (AI enrichment)
  dominantColor String? // Hex color
  colorPalette  Json? // Array of hex colors
  aiTags        Json? // Auto-detected tags
  altText       String? // Accessibility text
  caption       String? // Optional caption

  // Quality Metrics
  qualityScore  Float? // 0-100 from AI analysis
  isTransparent Boolean @default(false)
  hasBackground Boolean @default(true)

  // Processing Info
  processingError  String?
  processedAt      DateTime?
  processingTimeMs Int?

  // CDN & Storage
  cdnProvider String? @default("cloudinary") // cloudinary, s3, etc.
  storageKey  String? // Storage path/key
  cdnUrl      String? // CDN base URL

  // Audit
  uploadedById String?
  uploadedBy   User?     @relation("MediaUploadedBy", fields: [uploadedById], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  archivedAt   DateTime?

  @@index([skuItemId])
  @@index([styleCode])
  @@index([colorCode])
  @@index([type])
  @@index([status])
  @@index([isPrimary])
  @@map("product_media")
}

// Edit History for Manual Edit Engine
enum EditFieldType {
  TEXT
  NUMBER
  DECIMAL
  SELECT
  MULTISELECT
  DATE
  BOOLEAN
  JSON
}

enum EditStatus {
  PENDING // Awaiting approval
  APPROVED // Approved by manager
  REJECTED // Rejected with reason
  AUTO_APPROVED // Within auto-approve limits
}

model EditHistory {
  id String @id @default(cuid())

  // Reference to edited entity
  entityType String // SKUItem, OTBPlan, Budget, etc.
  entityId   String

  // Field Information
  fieldName  String
  fieldType  EditFieldType
  fieldLabel String? // Human-readable label

  // Values
  oldValue     String? @db.Text
  newValue     String? @db.Text
  oldValueJson Json? // For complex values
  newValueJson Json?

  // Variance Impact (for numeric fields)
  varianceAmount Decimal? @db.Decimal(18, 2)
  variancePct    Decimal? @db.Decimal(5, 2)

  // Cascade Info (what other fields were affected)
  cascadeInfo Json? // { affectedFields: [...], recalculations: [...] }

  // Status & Approval
  status           EditStatus @default(AUTO_APPROVED)
  requiresApproval Boolean    @default(false)
  approvalReason   String?

  // Approval Details
  approvedById    String?
  approvedBy      User?     @relation("EditApprovedBy", fields: [approvedById], references: [id])
  approvedAt      DateTime?
  rejectedById    String?
  rejectedBy      User?     @relation("EditRejectedBy", fields: [rejectedById], references: [id])
  rejectedAt      DateTime?
  rejectionReason String?

  // Context
  editReason String? // User-provided reason
  editSource String? // manual, import, ai_suggestion
  sessionId  String? // For grouping edits in a session

  // Audit
  editedById String
  editedBy   User     @relation("EditMadeBy", fields: [editedById], references: [id])
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([editedById])
  @@index([status])
  @@index([createdAt])
  @@index([sessionId])
  @@map("edit_history")
}

// Edit Permission Rules
model EditPermission {
  id String @id @default(cuid())

  // Who
  roleId String? // UserRole enum value
  userId String? // Specific user

  // What entity/field
  entityType   String // SKUItem, OTBPlan, etc.
  fieldPattern String // Field name or pattern (e.g., "price*", "*")

  // Conditions
  conditions Json? // { status: ["DRAFT"], variance: { max: 0.1 } }

  // Permissions
  canView    Boolean @default(true)
  canEdit    Boolean @default(false)
  canApprove Boolean @default(false)

  // Auto-approve limits
  autoApproveLimit    Decimal? @db.Decimal(18, 2) // Value limit
  autoApprovePctLimit Decimal? @db.Decimal(5, 2) // Percentage limit

  // Lock settings
  lockAfterApproval Boolean @default(true)
  requireReason     Boolean @default(false)

  isActive Boolean @default(true)
  priority Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roleId])
  @@index([entityType])
  @@index([isActive])
  @@map("edit_permissions")
}

// ============================================
// W25 FEATURES - THEME/USER PREFERENCES
// ============================================

model UserSettings {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation("UserSettingsUser", fields: [userId], references: [id], onDelete: Cascade)

  // Theme
  theme       String @default("light") // light, dark, system
  accentColor String @default("blue")

  // Localization
  language     String @default("vi") // vi, en
  dateFormat   String @default("DD/MM/YYYY")
  numberFormat String @default("vi-VN")
  currency     String @default("VND")
  timezone     String @default("Asia/Ho_Chi_Minh")

  // Default filters
  defaultSeasonId String?
  defaultBrandId  String?

  // Notifications
  emailNotifications Boolean  @default(true)
  pushNotifications  Boolean  @default(true)
  notificationTypes  String[] @default([]) // Array of enabled notification types

  // Table preferences
  tablePageSize    Int     @default(20)
  tableCompactMode Boolean @default(false)

  // Dashboard layout
  dashboardLayout Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_settings")
}

// ============================================
// SQL SCHEMA ALIGNED MODELS - APPROVAL WORKFLOW
// ============================================

// Enum for Approval Actions
enum ApprovalAction {
  APPROVED
  REJECTED
}

// Enum for Version Status (matches SQL schema)
enum VersionStatus {
  DRAFT
  SUBMITTED
  APPROVED
}

// ApprovalWorkflow - Maps to SQL: approval_workflow table
model ApprovalWorkflow {
  id           String     @id @default(cuid())
  groupBrandId String
  groupBrand   GroupBrand @relation("ApprovalWorkflowGroupBrand", fields: [groupBrandId], references: [id])
  workflowName String // Workflow name for display
  isActive     Boolean    @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  levels ApprovalWorkflowLevel[]

  @@index([groupBrandId])
  @@map("approval_workflows")
}

// ApprovalWorkflowLevel - Maps to SQL: approval_workflow_level table
model ApprovalWorkflowLevel {
  id                 String           @id @default(cuid())
  approvalWorkflowId String
  approvalWorkflow   ApprovalWorkflow @relation(fields: [approvalWorkflowId], references: [id], onDelete: Cascade)
  levelOrder         Int // Step 1, 2, 3...
  levelName          String // "Brand Manager Review", "Finance Review", "BOD Approval"
  approverUserId     String? // Specific user or NULL for any user with role
  isRequired         Boolean          @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  planApprovalLogs PlanApprovalLog[]

  @@unique([approvalWorkflowId, levelOrder])
  @@index([approvalWorkflowId])
  @@map("approval_workflow_levels")
}

// PlanApprovalLog - Maps to SQL: plan_approval_log table
model PlanApprovalLog {
  id                      String                @id @default(cuid())
  planHeaderId            String // Reference to the plan being approved
  approvalWorkflowLevelId String
  approvalWorkflowLevel   ApprovalWorkflowLevel @relation(fields: [approvalWorkflowLevelId], references: [id])
  approverUserId          String
  action                  ApprovalAction
  comment                 String?               @db.Text
  approvedAt              DateTime?

  createdAt DateTime @default(now())

  @@index([planHeaderId])
  @@index([approvalWorkflowLevelId])
  @@map("plan_approval_logs")
}

// ============================================
// SQL SCHEMA ALIGNED MODELS - BUDGET & PLANNING
// ============================================

// PlanBudget - Maps to SQL: budget table
// Main budget allocation per season/brand/store
model PlanBudget {
  id            String        @id @default(cuid())
  budgetName    String
  fiscalYear    Int
  seasonId      String
  season        Season        @relation("PlanBudgetSeason", fields: [seasonId], references: [id])
  groupBrandId  String
  groupBrand    GroupBrand    @relation("PlanBudgetGroupBrand", fields: [groupBrandId], references: [id])
  storeId       String
  store         Store         @relation("PlanBudgetStore", fields: [storeId], references: [id])
  versionCode   String // V1, V2, V3...
  versionStatus VersionStatus @default(DRAFT)
  budgetAmount  Decimal       @db.Decimal(18, 2)
  pctMix        Decimal       @db.Decimal(5, 2) // Percentage mix

  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  planCollections   PlanCollection[]  @relation("PlanCollectionBudget")
  planGenders       PlanGender[]      @relation("PlanGenderBudget")
  planSubcategories PlanSubcategory[] @relation("PlanSubcategoryBudget")

  @@index([seasonId])
  @@index([groupBrandId])
  @@index([storeId])
  @@index([fiscalYear])
  @@map("plan_budgets")
}

// PlanCollection - Maps to SQL: plan_collection table
model PlanCollection {
  id                 String        @id @default(cuid())
  planCollectionName String
  budgetId           String
  budget             PlanBudget    @relation("PlanCollectionBudget", fields: [budgetId], references: [id], onDelete: Cascade)
  versionCode        String // V1, V2, V3...
  versionStatus      VersionStatus @default(DRAFT)
  collectionId       String
  collection         Collection    @relation("PlanCollectionCollection", fields: [collectionId], references: [id])

  // Historical Performance
  actualBuyPct   Decimal? @db.Decimal(5, 2)
  actualSalesPct Decimal? @db.Decimal(5, 2)
  actualStPct    Decimal? @db.Decimal(5, 2) // Sell-through %
  actualMoc      Decimal? @db.Decimal(5, 2) // Months of cover

  // Proposed Values
  proposedBuyPct    Decimal? @db.Decimal(5, 2)
  otbProposedAmount Decimal? @db.Decimal(18, 2)
  pctVarVsLast      Decimal? @db.Decimal(5, 2) // % variance vs last year

  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([budgetId])
  @@index([collectionId])
  @@map("plan_collections")
}

// PlanGender - Maps to SQL: plan_gender table
model PlanGender {
  id             String        @id @default(cuid())
  planGenderName String
  budgetId       String
  budget         PlanBudget    @relation("PlanGenderBudget", fields: [budgetId], references: [id], onDelete: Cascade)
  genderId       String // Reference to Gender
  versionCode    String // V1, V2, V3...
  versionStatus  VersionStatus @default(DRAFT)

  // Historical Performance
  actualBuyPct   Decimal? @db.Decimal(5, 2)
  actualSalesPct Decimal? @db.Decimal(5, 2)
  actualStPct    Decimal? @db.Decimal(5, 2) // Sell-through %

  // Proposed Values
  proposedBuyPct    Decimal? @db.Decimal(5, 2)
  otbProposedAmount Decimal? @db.Decimal(18, 2)
  pctVarVsLast      Decimal? @db.Decimal(5, 2) // % variance vs last year

  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([budgetId])
  @@index([genderId])
  @@map("plan_genders")
}

// PlanSubcategory - Maps to SQL: plan_subcategory table
model PlanSubcategory {
  id                  String      @id @default(cuid())
  planSubcategoryName String
  budgetId            String
  budget              PlanBudget  @relation("PlanSubcategoryBudget", fields: [budgetId], references: [id], onDelete: Cascade)
  genderId            String
  subcategoryId       String
  subcategory         Subcategory @relation("PlanSubcategorySubcategory", fields: [subcategoryId], references: [id])

  // Historical Performance
  actualBuyPct   Decimal? @db.Decimal(5, 2)
  actualSalesPct Decimal? @db.Decimal(5, 2)
  actualStPct    Decimal? @db.Decimal(5, 2) // Sell-through %

  // Proposed Values
  proposedBuyPct    Decimal? @db.Decimal(5, 2)
  otbProposedAmount Decimal? @db.Decimal(18, 2)
  varLastYearPct    Decimal? @db.Decimal(5, 2) // Variance vs last year %

  // Actual Values (after approval)
  otbActualAmount Decimal? @db.Decimal(18, 2)
  otbActualBuyPct Decimal? @db.Decimal(5, 2)

  versionCode   String // V1, V2, V3...
  versionStatus VersionStatus @default(DRAFT)
  comment       String?       @db.Text

  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  proposalOrderSkus ProposalOrderSku[] @relation("ProposalOrderSkuPlanSubcategory")

  @@index([budgetId])
  @@index([subcategoryId])
  @@index([genderId])
  @@map("plan_subcategories")
}

// ============================================
// SQL SCHEMA ALIGNED MODELS - SKU PROPOSALS
// ============================================

// ProposalOrderSku - Maps to SQL: proposal_order_sku table
model ProposalOrderSku {
  id                   String          @id @default(cuid())
  proposalOrderSkuName String
  planSubcategoryId    String
  planSubcategory      PlanSubcategory @relation("ProposalOrderSkuPlanSubcategory", fields: [planSubcategoryId], references: [id], onDelete: Cascade)
  skuId                String // Reference to SKU
  proposalQuantity     Int // Order quantity (REX, TTP from image)
  unitCost             Decimal         @db.Decimal(18, 2)
  srp                  Decimal         @db.Decimal(18, 2) // Suggested Retail Price
  proposalValue        Decimal         @db.Decimal(18, 2) // TTL value
  customerTarget       String? // "New", "Existing", "Top VIC"

  versionCode   String // V1, V2, V3...
  versionStatus VersionStatus @default(DRAFT)

  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  proposalSkuSizings ProposalSkuSizing[] @relation("ProposalSkuSizingOrder")

  @@index([planSubcategoryId])
  @@index([skuId])
  @@map("proposal_order_skus")
}

// ProposalSkuSizing - Maps to SQL: proposal_sku_sizing table
model ProposalSkuSizing {
  id                 String           @id @default(cuid())
  proposalOrderSkuId String
  proposalOrderSku   ProposalOrderSku @relation("ProposalSkuSizingOrder", fields: [proposalOrderSkuId], references: [id], onDelete: Cascade)
  subcategorySizeId  String
  subcategorySize    SubcategorySize  @relation("ProposalSkuSizingSize", fields: [subcategorySizeId], references: [id])

  // Performance Data
  actualSalesMixPct Decimal? @db.Decimal(5, 2)
  actualStPct       Decimal? @db.Decimal(5, 2) // Sell-through %
  proposalQuantity  Int

  versionCode   String // V1, V2, V3...
  versionStatus VersionStatus @default(DRAFT)

  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  orderPlanSubmits OrderPlanSubmit[] @relation("OrderPlanSubmitProposalSizing")

  @@unique([proposalOrderSkuId, subcategorySizeId])
  @@index([proposalOrderSkuId])
  @@index([subcategorySizeId])
  @@map("proposal_sku_sizings")
}

// ============================================
// SQL SCHEMA ALIGNED MODELS - ORDER FLOW
// ============================================

// OrderPlanSubmit - Maps to SQL: order_plan_submit table
// Submitted order plan (snapshot of proposal after submission)
model OrderPlanSubmit {
  id                  String             @id @default(cuid())
  proposalSkuSizingId String?
  proposalSkuSizing   ProposalSkuSizing? @relation("OrderPlanSubmitProposalSizing", fields: [proposalSkuSizingId], references: [id])
  budgetId            String
  fiscalYear          Int
  seasonId            String
  season              Season             @relation("OrderPlanSubmitSeason", fields: [seasonId], references: [id])
  groupBrandId        String
  groupBrand          GroupBrand         @relation("OrderPlanSubmitGroupBrand", fields: [groupBrandId], references: [id])
  budgetName          String
  storeId             String
  store               Store              @relation("OrderPlanSubmitStore", fields: [storeId], references: [id])
  budgetAmount        Decimal            @db.Decimal(18, 2)
  pctMix              Decimal            @db.Decimal(5, 2)
  planHeaderId        String?
  productId           String?
  totalQuantity       Int
  unitCost            Decimal            @db.Decimal(18, 2)
  srp                 Decimal            @db.Decimal(18, 2)
  totalValue          Decimal            @db.Decimal(18, 2)
  subcategorySizeId   String?
  subcategorySize     SubcategorySize?   @relation("OrderPlanSubmitSize", fields: [subcategorySizeId], references: [id])
  quantity            Int

  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  orderPlanConfirms OrderPlanConfirm[] @relation("OrderPlanConfirmSubmit")

  @@index([budgetId])
  @@index([seasonId])
  @@index([groupBrandId])
  @@index([storeId])
  @@map("order_plan_submits")
}

// OrderPlanConfirm - Maps to SQL: order_plan_confirm table
// Confirmed order plan (after approval)
model OrderPlanConfirm {
  id                String           @id @default(cuid())
  orderPlanBudgetId String
  orderPlanSubmit   OrderPlanSubmit  @relation("OrderPlanConfirmSubmit", fields: [orderPlanBudgetId], references: [id])
  budgetId          String
  fiscalYear        Int
  seasonId          String
  season            Season           @relation("OrderPlanConfirmSeason", fields: [seasonId], references: [id])
  groupBrandId      String
  groupBrand        GroupBrand       @relation("OrderPlanConfirmGroupBrand", fields: [groupBrandId], references: [id])
  budgetName        String
  storeId           String
  store             Store            @relation("OrderPlanConfirmStore", fields: [storeId], references: [id])
  budgetAmount      Decimal          @db.Decimal(18, 2)
  pctMix            Decimal          @db.Decimal(5, 2)
  planHeaderId      String?
  productId         String?
  totalQuantity     Int
  unitCost          Decimal          @db.Decimal(18, 2)
  srp               Decimal          @db.Decimal(18, 2)
  totalValue        Decimal          @db.Decimal(18, 2)
  subcategorySizeId String?
  subcategorySize   SubcategorySize? @relation("OrderPlanConfirmSize", fields: [subcategorySizeId], references: [id])
  quantity          Int

  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  orderActualReceipts OrderActualReceipt[] @relation("OrderActualReceiptConfirm")

  @@index([orderPlanBudgetId])
  @@index([budgetId])
  @@index([seasonId])
  @@index([groupBrandId])
  @@index([storeId])
  @@map("order_plan_confirms")
}

// OrderActualReceipt - Maps to SQL: order_actual_receipt table
// Actual goods received (after delivery)
model OrderActualReceipt {
  id                String           @id @default(cuid())
  orderPlanBudgetId String
  orderPlanConfirm  OrderPlanConfirm @relation("OrderActualReceiptConfirm", fields: [orderPlanBudgetId], references: [id])
  budgetId          String
  fiscalYear        Int
  seasonId          String
  season            Season           @relation("OrderActualReceiptSeason", fields: [seasonId], references: [id])
  groupBrandId      String
  groupBrand        GroupBrand       @relation("OrderActualReceiptGroupBrand", fields: [groupBrandId], references: [id])
  budgetName        String
  storeId           String
  store             Store            @relation("OrderActualReceiptStore", fields: [storeId], references: [id])
  budgetAmount      Decimal          @db.Decimal(18, 2)
  pctMix            Decimal          @db.Decimal(5, 2)
  planHeaderId      String?
  productId         String?
  totalQuantity     Int
  unitCost          Decimal          @db.Decimal(18, 2)
  srp               Decimal          @db.Decimal(18, 2)
  totalValue        Decimal          @db.Decimal(18, 2)
  subcategorySizeId String?
  subcategorySize   SubcategorySize? @relation("OrderActualReceiptSize", fields: [subcategorySizeId], references: [id])
  quantity          Int

  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([orderPlanBudgetId])
  @@index([budgetId])
  @@index([seasonId])
  @@index([groupBrandId])
  @@index([storeId])
  @@map("order_actual_receipts")
}

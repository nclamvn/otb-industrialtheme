model ReplenishmentAlert {
  id String @id @default(cuid())

  // SKU Info
  skuId      String
  skuCode    String
  skuName    String
  brandId    String?
  categoryId String?
  locationId String?

  // Alert Type
  alertType String // LOW_MOC, STOCKOUT_RISK, REORDER_POINT, LEAD_TIME_WARNING

  // Current State
  currentStock   Int
  currentMOC     Decimal @db.Decimal(4, 2)

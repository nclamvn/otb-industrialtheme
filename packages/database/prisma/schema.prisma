// ============================================
// AUTOMATION RULES
// ============================================

model AutomationRule {
  id String @id @default(cuid())

  // Basic info
  name        String
  description String? @db.Text
  type        String // AUTO_APPROVE_BUDGET, AUTO_APPROVE_OTB, AUTO_APPROVE_SKU, AUTO_REORDER, AUTO_ESCALATE, AUTO_NOTIFY

  // Rule configuration
